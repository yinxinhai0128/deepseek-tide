{
  "name": "deepseek-tide-desktop",
  "version": "0.3.4",
  "private": true,
  "author": "DeepSeek-Tide Contributors",
  "description": "A focused desktop coding agent powered by DeepSeek and CodeWhale",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite --configLoader runner --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "build:renderer": "tsc --noEmit && vite build --configLoader runner",
    "build": "npm run build:renderer && electron-builder --win nsis portable",
    "preview": "vite preview",
    "test": "node --test electron/*.test.cjs"
  },
  "dependencies": {
    "@fontsource-variable/dm-sans": "^5.2.8",
    "@tabler/icons-react": "^3.41.1",
    "clsx": "^2.1.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.5.2",
    "concurrently": "^9.1.2",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.2",
    "playwright": "^1.60.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "ai.deepseek.tide",
    "productName": "DeepSeek-Tide",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../vendor/codewhale",
        "to": "codewhale",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../LICENSE",
        "to": "legal/DEEPSEEK-TIDE-LICENSE.txt"
      },
      {
        "from": "../THIRD_PARTY_NOTICES.md",
        "to": "legal/THIRD_PARTY_NOTICES.md"
      },
      {
        "from": "legal/CODEWHALE-LICENSE.txt",
        "to": "legal/CODEWHALE-LICENSE.txt"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis",
        "portable"
      ],
      "artifactName": "DeepSeek-Tide-${version}-${arch}.${ext}"
    },
    "nsis": {
      "artifactName": "DeepSeek-Tide-Setup-${version}-${arch}.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "portable": {
      "artifactName": "DeepSeek-Tide-Portable-${version}-${arch}.${ext}"
    }
  }
}
